{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Main Atomic Task Ledger",
  "type": "object",
  "required": [
    "schema_version",
    "tasks"
  ],
  "properties": {
    "schema_version": {
      "type": "string"
    },
    "source_of_truth": {
      "type": "string"
    },
    "status_values": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "tasks": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "id",
          "title",
          "status",
          "dependencies",
          "objective",
          "inputs",
          "write_scope",
          "authority",
          "acceptance_criteria",
          "verification",
          "stop_condition"
        ],
        "properties": {
          "id": {
            "type": "string",
            "minLength": 1
          },
          "title": {
            "type": "string",
            "minLength": 1
          },
          "status": {
            "enum": [
              "not_started",
              "in_progress",
              "blocked",
              "done"
            ]
          },
          "phase": {
            "type": "string"
          },
          "dependencies": {
            "type": "array",
            "uniqueItems": true,
            "items": {
              "type": "string",
              "minLength": 1
            }
          },
          "objective": {
            "type": "string",
            "minLength": 1
          },
          "inputs": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string",
              "minLength": 1
            }
          },
          "write_scope": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string",
              "minLength": 1
            }
          },
          "authority": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string",
              "minLength": 1
            }
          },
          "acceptance_criteria": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string",
              "minLength": 1
            }
          },
          "verification": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string",
              "minLength": 1
            }
          },
          "stop_condition": {
            "type": "string",
            "minLength": 1
          },
          "evidence": {
            "type": "string"
          },
          "notes": {
            "type": "string"
          }
        },
        "additionalProperties": true
      }
    }
  }
}
