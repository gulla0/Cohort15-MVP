# Cohort15 local development defaults. Copy to .env.local for personal use.
# Do not commit real secrets.

COHORT15_APP_ENV=development
COHORT15_APP_URL=http://localhost:3000
COHORT15_UPLOAD_MODE=local

# Optional durable local state.
# COHORT15_PERSISTENCE_FILE=.local/cohort15-state.json

# Production-only values documented in docs/production-config.md.
# COHORT15_SESSION_SECRET=
# COHORT15_ADMIN_EMAILS=
# SUPABASE_URL=
# SUPABASE_ANON_KEY=
# SUPABASE_SERVICE_ROLE_KEY=
# SUPABASE_AUTH_CALLBACK_PATH=/auth/callback
# SUPABASE_ENABLE_MAGIC_LINK=false
# STRIPE_SECRET_KEY=
# STRIPE_WEBHOOK_SECRET=
# STRIPE_PRICE_6_CREDITS=
# STRIPE_PRICE_14_CREDITS=
# LINKEDIN_CLIENT_ID=
# LINKEDIN_CLIENT_SECRET=
# X_API_KEY=
# X_API_SECRET=
# EMAIL_PROVIDER_API_KEY=
# EMAIL_FROM_ADDRESS=
